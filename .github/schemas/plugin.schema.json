{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude Code plugin manifest",
  "description": "Schema para .claude-plugin/plugin.json. Reflete o que o validador interno do Claude Code (/plugin install) aceita.",
  "type": "object",
  "required": ["name", "version"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Slug kebab-case; identifica o plugin no marketplace."
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][0-9A-Za-z.-]+)?$",
      "description": "SemVer X.Y.Z."
    },
    "author": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["name"],
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "url": { "type": "string", "format": "uri" }
          }
        }
      ]
    },
    "homepage": { "type": "string", "format": "uri" },
    "repository": {
      "type": "string",
      "description": "URL git como string. NUNCA objeto — o Claude Code rejeita {type,url}."
    },
    "license": { "type": "string" },
    "keywords": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
